# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/nebula_v2"

# NextAuth
AUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# SMTP — envio de e-mails (recuperação de senha)
# Gmail: habilite "Senhas de app" em myaccount.google.com/security
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="seu@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="Nebula <noreply@seudominio.com>"

# Optional: OAuth providers
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
